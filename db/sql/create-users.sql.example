CREATE USER IF NOT EXISTS 'appuser'@'%' IDENTIFIED BY '<APP_DB_PASSWORD>';
GRANT ALL PRIVILEGES ON appdb.* TO 'appuser'@'%';

CREATE USER IF NOT EXISTS 'repl'@'192.168.101.32' IDENTIFIED BY '<REPLICATION_PASSWORD>';
GRANT REPLICATION SLAVE ON *.* TO 'repl'@'192.168.101.32';

CREATE USER IF NOT EXISTS 'maxscale'@'192.168.101.%' IDENTIFIED BY '<MAXSCALE_PASSWORD>';
GRANT ALL PRIVILEGES ON *.* TO 'maxscale'@'192.168.101.%' WITH GRANT OPTION;

FLUSH PRIVILEGES;
